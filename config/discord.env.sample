# ============================================================
# Discord 統合 env (cmd_658 ntfy→Discord 移行で導入)
#
# 役割:
#   - notify.sh / discord_notify.py / discord_gateway.py で共有
#   - 既存 config/discord_bot.env (DM relay 用) と並存し、最終的には統合
#
# セットアップ:
#   cp config/discord.env.sample config/discord.env
#   chmod 600 config/discord.env
#   # 値を編集して保存 (.gitignore 済み — git に commit しない)
# ============================================================

# Discord Bot Token
# Discord Developer Portal (https://discord.com/developers/applications) で取得
# 既存 config/discord_bot.env の DISCORD_BOT_TOKEN と同じ値を設定可
DISCORD_BOT_TOKEN=your_bot_token_here

# 許可ユーザー ID (受信用 — DM allowlist; カンマ区切り)
# 開発者モード ON → ユーザー右クリック → ID コピー
DISCORD_ALLOWED_USER_IDS=your_user_id_here

# 殿への送信先 DM チャネル ID (送信用 — outbound notification)
# Bot が殿と DM を一度交わすと自動的に DM チャネルが生成される。
# その DM チャネル ID を Developer Mode で取得するか、Bot 内部 API で
# DISCORD_LORD_USER_ID から open_dm により解決する設計とする。
# (未設定時は DISCORD_LORD_USER_ID を直接利用 → discord_notify.py 側で open_dm)
DISCORD_LORD_DM_CHANNEL_ID=

# 殿の Discord User ID (DISCORD_LORD_DM_CHANNEL_ID 未設定時の DM 送信先)
# DISCORD_ALLOWED_USER_IDS の最初の値と同じで良い場合が多い
DISCORD_LORD_USER_ID=your_user_id_here

# 通知バックエンド: discord (default) | ntfy (Phase 1 fallback)
# Phase 1 では default=discord、ntfy.sh は wrapper 経由で呼出可能
NOTIFY_BACKEND=discord
